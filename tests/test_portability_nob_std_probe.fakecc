#!/bin/sh
set -eu
log=${PROVEN_STD_PROBE_LOG:-tests/test_portability_nob_std_probe.log}
real_cc=${PROVEN_STD_PROBE_REAL_CC:-cc}
for arg in "$@"; do
  if [ "$arg" = "-std=c23" ]; then
    printf '%s\n' "reject c23: $*" >> "$log"
    exit 1
  fi
done
for arg in "$@"; do
  if [ "$arg" = "-std=c2x" ]; then
    printf '%s\n' "accept c2x: $*" >> "$log"
    exec "$real_cc" "$@"
  fi
done
printf '%s\n' "missing standard flag: $*" >> "$log"
exec "$real_cc" "$@"
